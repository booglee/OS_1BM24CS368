#include <stdio.h>
#include <time.h>
#include <stdlib.h>

#define n 3

int main() {
    int tt = 0;
    int lottery = 0;
    int processes[3] = {1, 2, 4};
    int tickets[3] = {10, 20, 30};
    for (int i = 0; i < n; i++) {
        tt += tickets[i];
        for (int j = i + 1; j < n; j++) {
            if (tickets[i] < tickets[j]) {
                // Swap tickets
                int temp = tickets[i];
                tickets[i] = tickets[j];
                tickets[j] = temp;
                // Swap processes
                temp = processes[i];
                processes[i] = processes[j];
                processes[j] = temp;
            }
        }
    }
    srand(time(0));
    lottery = rand() % tt; 
    printf("Selected ticket: %d\n", lottery);
    lottery=lottery%50;
    
    for (int i = 0; i < n; i++) {
        lottery -= tickets[i];
        if (lottery < 0) {
            printf("Selected Process: %d\n", processes[i]);
            break;
        }
    }

    return 0;
}
