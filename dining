#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>
#include <pthread.h>
#include <unistd.h> // Required for sleep()

#define NUM_PHIL 5

pthread_mutex_t FORKS[NUM_PHIL];

void* philosopher(void* num) {
    int id = *(int*)num; // Corrected pointer casting
    
    while(true) {
        printf("Philosopher %d is thinking...\n", id);
        sleep(1);

        // Deadlock avoidance logic
        if(id == NUM_PHIL - 1) {
            // Last philosopher picks up right fork then left
            pthread_mutex_lock(&FORKS[(id + 1) % NUM_PHIL]);
            pthread_mutex_lock(&FORKS[id]);
        } else {
            // Others pick up left fork then right
            pthread_mutex_lock(&FORKS[id]);
            pthread_mutex_lock(&FORKS[(id + 1) % NUM_PHIL]);
        }

        printf("Philosopher %d is eating 🍝\n", id);
        sleep(2);

        // Always unlock in the same order
        pthread_mutex_unlock(&FORKS[id]);
        pthread_mutex_unlock(&FORKS[(id + 1) % NUM_PHIL]);
        
        printf("Philosopher %d finished eating.\n", id);
    }
    return NULL;
}

int main() {
    pthread_t phils[NUM_PHIL];
    int ids[NUM_PHIL];

    // Initialize mutexes
    for(int i = 0; i < NUM_PHIL; i++) {
        pthread_mutex_init(&FORKS[i], NULL);
    }

    // Create threads
    for(int i = 0; i < NUM_PHIL; i++) {
        ids[i] = i;
        pthread_create(&phils[i], NULL, philosopher, &ids[i]);
    }

    // Join threads (keeps the main process alive)
    for(int i = 0; i < NUM_PHIL; i++) {
        pthread_join(phils[i], NULL);
    }

    return 0;
}
